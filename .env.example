KOMARI_PORT=25774

KOMARI_DB_HOST=127.0.0.1
KOMARI_DB_PORT=3306
KOMARI_DB_NAME=komari
KOMARI_DB_USER=komari
KOMARI_DB_PASS=change-me
KOMARI_DB_ROOT_PASS=change-root-password

# Comma-separated browser origins allowed when allow_cors is enabled in system settings.
# Leave empty for same-host origins only, for example: https://monitor.example.com
KOMARI_CORS_ALLOWED_ORIGINS=
# Optional extra browser origins for WebSocket endpoints. CORS origins are reused automatically.
KOMARI_WS_ALLOWED_ORIGINS=

# Login brute-force protection. Durations accept Go-style values such as 10m or raw seconds.
KOMARI_LOGIN_MAX_FAILURES=8
KOMARI_LOGIN_WINDOW=10m
KOMARI_LOGIN_LOCKOUT=15m

# HTTP server hardening. Keep write timeout at 0 unless you have no WebSocket/MJPEG/long cloud operations.
KOMARI_HTTP_READ_HEADER_TIMEOUT=10s
KOMARI_HTTP_READ_TIMEOUT=0
KOMARI_HTTP_WRITE_TIMEOUT=0
KOMARI_HTTP_IDLE_TIMEOUT=120s
KOMARI_HTTP_MAX_BODY_BYTES=4194304

# Send Strict-Transport-Security when the request is HTTPS or forwarded as HTTPS.
KOMARI_SECURITY_HSTS=false

# Keep this stable across backups/restores if you store cloud root passwords.
KOMARI_CLOUD_SECRET_KEY=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=
